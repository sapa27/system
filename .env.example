# Phase N Vercel API proxy configuration
# Server-side only: do NOT prefix this with NEXT_PUBLIC unless you intentionally want a browser fallback.
GAS_WEB_APP_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# Optional public values
NEXT_PUBLIC_APP_LOGO_URL=
NEXT_PUBLIC_VERCEL_API_PROXY_URL=/api/gas
NEXT_PUBLIC_VERCEL_LOGIN_PROXY_URL=/api/login
NEXT_PUBLIC_VERCEL_PUBLIC_CONFIG_PROXY_URL=/api/public-config

# Optional timeouts in milliseconds
GAS_PROXY_TIMEOUT_MS=55000
GAS_LOGIN_PROXY_TIMEOUT_MS=30000
GAS_PUBLIC_CONFIG_TIMEOUT_MS=8000
